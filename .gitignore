__pycache__/
*.pyc
*.pyo
*.pyd

# --- Secrets / Environment Variables ---
.env
*.env.*
!*.env.example  # Kecualikan file contoh .env jika ada

# --- Temporary Files ---
*.tmp
*.swp

# --- Specific to your project (Contoh) ---
